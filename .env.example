# Database
DATABASE_URL=postgres://notion:notion@localhost:5434/notion?sslmode=disable

# Server
PORT=8080
DEV_MODE=true

# JWT secret (generate a strong random string for production)
JWT_SECRET=dev-secret-change-in-production

# CORS origins (space-separated, only used in dev mode)
CORS_ORIGINS=http://localhost:5173 http://localhost:8080

# Production app URL (sets CORS origin in production mode)
APP_URL=

# Storage (optional, for local development)
STORAGE_EMULATOR_HOST=http://localhost:4443
